{
  "name": "registre-numerique",
  "version": "1.0.2",
  "description": "Application de registre des visiteurs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"wait-on http://localhost:5173 && electron .\"",
    "server": "node backend/server.js",
    "client": "cd frontend && npm run dev",
    "build:react": "cd frontend && npm install && npm run build",
    "build:electron": "electron-builder -w",
    "build": "npm run build:react && npm run build:electron"
  },
  "build": {
    "appId": "com.rn.registre.numerique",
    "productName": "RN - Registre Numerique",
    "buildVersion": "1.0.1.4",
    "directories": {
      "output": "deploy_build",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "!backend/database.sqlite",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Registre Numerique",
      "license": "license.txt"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "init2578-cpu",
        "repo": "RN-Registre-Numerique"
      }
    ]
  },
  "keywords": [
    "react",
    "electron",
    "registre",
    "visiteurs"
  ],
  "author": "CRE KOLDA",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}